rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && request.auth.token.admin == true; }

    // Players: everyone signed in can read, only admins can write.
    match /players/{playerId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // Teams: everyone signed in can read. Signed-in users can create teams.
    // Only the creator can update/delete their own team.
    match /teams/{teamId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if signedIn()
        && resource.data.createdBy == request.auth.uid;
    }

    // Game state: readable by signed-in users; writable by admins.
    match /gameState/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Game state (players list + current gameweek)
    // Any signed-in user can read. Any signed-in user can write
    // (admin PIN gates the UI — no server-side admin claims needed for a club app).
    match /gameState/{doc} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Teams — one document per user, keyed by their Firebase UID.
    // Any signed-in user can read all teams (leaderboard).
    // A user can only write their own team document.
    match /teams/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
