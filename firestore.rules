rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && request.auth.token.admin == true; }

    // Players: everyone signed in can read, only admins can write.
    match /players/{playerId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // Teams: doc id is the manager’s Firebase uid. (Legacy docs may omit createdBy.)
    match /teams/{teamId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && teamId == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if signedIn() && teamId == request.auth.uid;
    }

    // Game state: readable by signed-in users; writable by admins.
    match /gameState/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // Snapshots: admin-only (used for rewind/restore).
    match /snapshots/{snapshotId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
